# ─────────────────────────────────────────
# Patitas Unidas — Variables de entorno
# Copia este archivo a .env y completa los valores
# ─────────────────────────────────────────

# Supabase
# Consíguelos en: supabase.com → tu proyecto → Settings → API
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGci...

# Conekta (pagos)
# Consíguelo en: app.conekta.com → Configuración → API Keys → Llave pública
VITE_CONEKTA_PUBLIC_KEY=key_xxxxxxxxxxxxxxxxxx


# Google Maps (para el mapa de albergues)
# Consíguelo en: console.cloud.google.com → APIs → Maps JavaScript API
# Activa también: Maps JavaScript API y Places API
VITE_GOOGLE_MAPS_KEY=AIzaSy_xxxxxxxxxxxxxxxxxxxxxxxx
